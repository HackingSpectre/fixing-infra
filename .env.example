# NODE_ENV=development
# PORT=5050
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/deta_infra
# DATABASE_URL_DIRECT=postgres://postgres:postgres@localhost:5432/deta_infra
# DB_POOL_MAX=5
# DB_IDLE_TIMEOUT_SECONDS=30
# DB_CONNECT_TIMEOUT_SECONDS=30
# DB_SSL_MODE=auto
# REDIS_URL=redis://localhost:6379
# QUEUE_MODE=inline
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# APP_JWT_SECRET=replace-with-long-random-secret
# APP_JWT_EXPIRES_IN=1h
# IKA_NETWORK=testnet
# IKA_SUI_RPC_URL=https://fullnode.testnet.sui.io:443
# IKA_SUI_RPC_URLS=https://sui-testnet.g.alchemy.com/v2/your-key,https://sui-testnet.publicnode.com
# IKA_SIGNER_SECRET_KEY_BASE64=base64_or_suiprivkey_encoded_sponsor_private_key
# IKA_USER_SHARE_ROOT_SEED_BASE64=base64_encoded_root_seed_32_bytes
# IKA_FEE_IKA_COIN_OBJECT_ID=
# IKA_FEE_IKA_COIN_TYPE=0x1f26bb2f711ff82dcda4d02c77d5123089cb7f8418751474b9fb744ce031526a::ika::IKA
# IKA_FEE_SUI_AMOUNT_MIST=1000000
# IKA_ACTIVE_POLL_INTERVAL_MS=1000
# IKA_ACTIVE_POLL_TIMEOUT_MS=60000
# GAS_SOFT_THRESHOLD_SUI=10
# GAS_SOFT_THRESHOLD_IKA=10
# GAS_HARD_THRESHOLD_SUI=1
# GAS_HARD_THRESHOLD_IKA=1
# LOG_LEVEL=info

