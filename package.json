{
  "name": "deta-infra",
  "version": "0.2.0",
  "type": "module",
  "private": true,
  "description": "Deta multichain wallet infrastructure service",
  "main": "dist/index.js",
  "scripts": {
    "dev": "NODE_OPTIONS=--dns-result-order=ipv4first tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "NODE_OPTIONS=--dns-result-order=ipv4first node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:setup": "npm run db:generate && npm run db:migrate"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@ika.xyz/sdk": "0.3.1",
    "@mysten/sui": "^2.0.0",
    "@noble/hashes": "^1.8.0",
    "@noble/secp256k1": "^3.0.0",
    "@scure/base": "^1.2.6",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "bullmq": "^5.58.5",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.6.1",
    "ioredis": "^5.8.1",
    "jose": "^5.9.6",
    "jsonwebtoken": "^9.0.2",
    "postgres": "^3.4.8",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.3.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^4.0.0"
  }
}
